<routes>
    <vType id="car" accel="1.0" decel="4.5" length="5" maxSpeed="20"/>

    <!-- Straight routes -->
    <route id="north_straight" edges="north_in south_out"/>
    <route id="south_straight" edges="south_in north_out"/>

    <!-- Left turns -->
    <route id="north_left" edges="north_in east_out"/>
    <route id="south_left" edges="south_in west_out"/>

    <!-- Vehicles -->
    <vehicle id="v1" type="car" route="north_straight" depart="0"/>
    <vehicle id="v2" type="car" route="north_left" depart="2"/>
    <vehicle id="v3" type="car" route="south_straight" depart="4"/>
    <vehicle id="v4" type="car" route="south_left" depart="6"/>

</routes>